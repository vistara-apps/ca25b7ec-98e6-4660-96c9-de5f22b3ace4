# OnchainKit API Key (required for Base Mini App functionality)
NEXT_PUBLIC_ONCHAINKIT_API_KEY=your_onchainkit_api_key_here

# OpenAI API Key (for AI companion functionality)
OPENAI_API_KEY=your_openai_api_key_here

# Base App Configuration
NEXT_PUBLIC_APP_URL=https://echosphere.app
NEXT_PUBLIC_FRAME_URL=https://echosphere.app

# Farcaster Hub Configuration (optional)
FARCASTER_HUB_URL=https://hub.farcaster.xyz
